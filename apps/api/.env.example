NODE_ENV=development
PORT=7000
DATABASE_URL=postgres://riftbound:riftbound@localhost:5433/riftbound
# Optional: e2e tests use this instead of DATABASE_URL when set.
TEST_DB_URL=postgres://riftbound:riftbound@localhost:5433/riftbound_test
RIFTRUNE_API_KEY=ak_your_key_here
RIFTRUNE_BASE_URL=https://piltoverarchive.com/api/external
ADMIN_SYNC_TOKEN=dev-sync-token-change-me

# Piltoverarchive deck creation/update appears to require partner identification.
# Optional: forwarded as an extra header on upstream deck create/delete calls.
# Example values:
# UPSTREAM_DECK_WRITE_EXTRA_HEADER_NAME=x-partner-id
# UPSTREAM_DECK_WRITE_EXTRA_HEADER_VALUE=your-partner-id
UPSTREAM_DECK_WRITE_EXTRA_HEADER_NAME=
UPSTREAM_DECK_WRITE_EXTRA_HEADER_VALUE=

SYNC_CRON_ENABLED=true
# Cardmarket daily price guide export — Riftbound idGame is 22
CARDMARKET_GAME_ID=22

# Better Auth (generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me-in-production
# Local dev:
BETTER_AUTH_URL=http://localhost:7000
# Railway (backend service) — resolved from each service's public domain:
# BETTER_AUTH_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
# TRUSTED_ORIGINS=https://${{RAILWAY_SERVICE_EXPO_WEB_URL}}
# AUTH_COOKIE_DOMAIN is optional; auto-derived from API + frontend hostnames in production.

# Cloudflare R2 image cache (EU jurisdiction endpoint)
# Create S3 API credentials in Cloudflare dashboard → R2 → Manage R2 API tokens
S3_ENDPOINT=https://<account-id>.eu.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=riftbound
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Runtime tuning (production defaults shown)
# DB_POOL_MAX=5
# SWAGGER_ENABLED=false
# CATALOG_WARMUP_ON_START=false

# --- Cloudflare Tunnel (run separately: `bun run cloudflared`) ---
# https://riftbounddev.roan.dev → API :7000 (/api/v1, /api/auth, /swagger) + Expo :7001
# See cloudflared/config.yml
