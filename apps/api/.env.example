NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://riftbound:riftbound@localhost:5433/riftbound
# Optional: e2e tests use this instead of DATABASE_URL when set.
TEST_DB_URL=postgres://riftbound:riftbound@localhost:5433/riftbound_test
RIFTRUNE_API_KEY=ak_your_key_here
RIFTRUNE_BASE_URL=https://piltoverarchive.com/api/external
ADMIN_SYNC_TOKEN=dev-sync-token-change-me
SYNC_CRON_ENABLED=true

# Better Auth (generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me-in-production
# When using the Cloudflare tunnel, set this to the tunnel URL:
BETTER_AUTH_URL=https://riftbounddev.roan.dev
# For local-only dev without tunnel: BETTER_AUTH_URL=http://localhost:3000

# --- Cloudflare Tunnel (run separately: `bun run cloudflared`) ---
# https://riftbounddev.roan.dev → API :3000 (/v1, /api/auth, /swagger) + Expo :8081
# See cloudflared/config.yml
# PUBLIC_API_URL=https://riftbounddev.roan.dev
