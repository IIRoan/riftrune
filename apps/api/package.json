{
  "name": "@riftbound/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "bun scripts/reset-db.ts --local",
    "db:reset:full": "bun scripts/reset-db.ts --local --catalog --prices",
    "db:studio": "drizzle-kit studio",
    "sync:prices": "bun scripts/sync-cardmarket-prices.ts",
    "test": "bun scripts/run-tests.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@better-auth/expo": "^1.6.23",
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/swagger": "^1.3.0",
    "@riftbound/contracts": "workspace:*",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.3.5",
    "postgres": "^3.4.7",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@riftbound/typescript-config": "workspace:*",
    "@types/bun": "^1.2.15",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3"
  }
}
