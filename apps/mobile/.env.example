# Local web / simulator against a machine-local API:
# EXPO_PUBLIC_API_URL=http://localhost:7000
#
# Expo Go / device / EAS Update (default in code if unset):
EXPO_PUBLIC_API_URL=https://riftapi.solace.onl
#
# Optional: written by `bun run cloudflared` for a named tunnel hostname.
# EXPO_DEV_SERVER_ORIGIN=https://riftbounddev.roan.dev
#
# Browser / agent test account for riftbounddev (gitignored in .env):
# RIFTRUNE_TEST_EMAIL=
# RIFTRUNE_TEST_PASSWORD=
