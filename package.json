{
  "name": "riftrune",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "bun run --cwd apps/api dev",
    "dev:api": "bun run dev:backend",
    "dev:mobile": "bun run --cwd apps/mobile dev",
    "cloudflared": "bun scripts/dev-tunnel.mjs",
    "build": "turbo build",
    "lint": "eslint \"apps/**/*.{ts,tsx,js,mjs}\" \"packages/**/*.{ts,tsx,js,mjs}\" \"design/**/*.{ts,tsx,js,mjs}\" --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/.next/**\"",
    "lint:fix": "bun run lint --fix",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @riftbound/api test:e2e",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @riftbound/api db:migrate",
    "db:generate": "pnpm --filter @riftbound/api db:generate",
    "db:studio": "pnpm --filter @riftbound/api db:studio",
    "sync:catalog": "curl -s -X POST http://localhost:3000/v1/sync/catalog -H \"Authorization: Bearer ${ADMIN_SYNC_TOKEN:-dev-sync-token-change-me}\"",
    "sync:prices": "curl -s -X POST http://localhost:3000/v1/sync/prices -H \"Authorization: Bearer ${ADMIN_SYNC_TOKEN:-dev-sync-token-change-me}\"",
    "db:setup": "pnpm db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  }
}
